
@{
    ViewData["Title"] = "About";
}



    <!-- SAYFA BAŞLIĞI (ABOUT HERO) -->
    <section class="about-hero">
        <div class="container text-center">
            <h1>Gayrimenkulde Güvenin ve Teknolojinin Adresi</h1>
            <p>Acentalar ile hayalindeki evi arayanları şeffaf, hızlı ve modern bir ekosistemde buluşturuyoruz.</p>
        </div>
    </section>

    <!-- HİKAYEMİZ & VİZYONUMUZ -->
    <section class="section container">
        <div class="about-grid">
            <div class="about-text">
                <span class="sub-title">Biz Kimiz?</span>
                <h2>Emlak Arayışını ve Satışını Yeniden Tanımlıyoruz</h2>
                <p>2024 yılında kurulan <strong>EmlakVitrini</strong>, geleneksel gayrimenkul süreçlerini dijital dünyanın hızı ve şeffaflığı ile harmanlayan yeni nesil bir pazaryeridir.</p>
                <p>Amacımız sadece bir ilan sitesi olmak değil; profesyonel gayrimenkul acentaları ile alıcıları en doğru veriler, gelişmiş filtreleme seçenekleri ve güvenilir portföyler üzerinden bir araya getiren bir çözüm ortağı olmaktır.</p>

                <div class="mission-vision-box">
                    <div class="mv-item">
                        <h4><i class="fa-solid fa-bullseye"></i> Misyonumuz</h4>
                        <p>Gayrimenkul ticaretinde bilgi kirliliğini önleyerek, onaylı acentalar aracılığıyla kullanıcılara %100 güvenilir ilanlar sunmak.</p>
                    </div>
                    <div class="mv-item">
                        <h4><i class="fa-solid fa-eye"></i> Vizyonumuz</h4>
                        <p>Türkiye'nin ve bölgenin en çok tercih edilen, yapay zeka destekli lider gayrimenkul ve acente platformu olmak.</p>
                    </div>
                </div>
            </div>
            <div class="about-image">
                <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80" alt="EmlakVitrini Ofis ve Ekip">
                <div class="experience-badge">
                    <strong>10+</strong>
                    <span>Yıllık Sektör<br>Tecrübesi</span>
                </div>
            </div>
        </div>
    </section>

    <!-- RAKAMLARLA BİZ (İSTATİSTİKLER) -->
    <section class="section bg-light">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-card">
                    <i class="fa-solid fa-building-circle-check"></i>
                    <h3>500+</h3>
                    <p>Onaylı Acenta</p>
                </div>
                <div class="stat-card">
                    <i class="fa-solid fa-house-circle-check"></i>
                    <h3>15.000+</h3>
                    <p>Aktif ve Doğrulanmış İlan</p>
                </div>
                <div class="stat-card">
                    <i class="fa-solid fa-users"></i>
                    <h3>50.000+</h3>
                    <p>Mutlu Ev Sahibi & Kiracı</p>
                </div>
                <div class="stat-card">
                    <i class="fa-solid fa-map-location-dot"></i>
                    <h3>81</h3>
                    <p>İlde Aktif Hizmet</p>
                </div>
            </div>
        </div>
    </section>

    <!-- DEĞERLERİMİZ -->
    <section class="section container">
        <div class="section-header text-center" style="margin-bottom: 50px;">
            <div>
                <h2>Bizi Farklı Kılan Değerler</h2>
                <p>Platformumuzu inşa ederken ve acentalarımızla işbirliği yaparken taviz vermediğimiz ilkelerimiz</p>
            </div>
        </div>

        <div class="values-grid">
            <div class="value-card">
                <div class="value-icon"><i class="fa-solid fa-shield-halved"></i></div>
                <h3>Onaylı Acenta Sistemi</h3>
                <p>Platformumuzdaki tüm acentalar yetki belgeleri kontrol edilerek sisteme dahil edilir. Sahte veya yanıltıcı ilanlara yer yoktur.</p>
            </div>

            <div class="value-card">
                <div class="value-icon"><i class="fa-solid fa-chart-line"></i></div>
                <h3>Veri Odaklı Analiz</h3>
                <p>Alıcılar ve satıcılar için bölge bazlı fiyat endeksleri ve reel piyasa verileri sunarak doğru yatırım kararları alınmasını sağlarız.</p>
            </div>

            <div class="value-card">
                <div class="value-icon"><i class="fa-solid fa-handshake-angle"></i></div>
                <h3>Acenta Dostu Altyapı</h3>
                <p>İş ortaklarımız olan emlak ofislerinin portföylerini en iyi şekilde sergileyebilmeleri için gelişmiş CRM ve yönetim araçları sunarız.</p>
            </div>
        </div>
    </section>

    <!-- ACENTALAR İÇİN ÇAĞRI (CTA) -->
    <section class="section cta-section">
        <div class="container cta-content">
            <h2>Siz De Güvenilir Acentalarımız Arasına Katılın</h2>
            <p>Portföyünüzü binlerce potansiyel alıcıyla buluşturun, kurumsal marka değerinizi EmlakVitrini ayrıcalığıyla yükseltin.</p>
            <a href="#" class="btn btn-primary" style="background-color: var(--white); color: var(--primary-color); font-size: 1.1rem; padding: 12px 30px;">Hemen Acenta Başvurusu Yap</a>
        </div>
    </section>

    
